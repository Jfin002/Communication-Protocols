void OLED_ShowCount(int count)
{
    char buffer[10];

    /* Clear only the display area */
    for(uint8_t page = 0; page < 6; page++) // Pages 0-5 only
    {
        OLED_SetCursor(page, 0);
        for(uint8_t col = 0; col < 128; col++)
        {
            OLED_Data(0x00);
        }
    }

    /* Display "PERSONS ENTERED" */
    OLED_SetCursor(0, 20);
    OLED_Print("PERSONS");

    OLED_SetCursor(2, 25);
    OLED_Print("ENTERED");

    /* Display count - BIG FONT style */
    intToStr(count, buffer);

    /* Position count in center for 3-digit max */
    uint8_t count_x = 55 - (strlen(buffer) * 3); // Center align
    OLED_SetCursor(4, count_x);

    /* Print each digit BIG (5x7 scaled) */
    for(int i = 0; i < strlen(buffer); i++)
    {
        OLED_DrawChar(buffer[i]);
        /* Add spacing between digits */
        OLED_SetCursor(4, count_x + (i * 6));
    }

    /* Small delay to ensure I2C completes */
    for(volatile uint32_t i = 0; i < 5000; i++);
}

