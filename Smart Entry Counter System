void delay_ms(uint32_t ms)
{
    for(uint32_t i = 0; i < (ms * 4000); i++)
    {
        __NOP();
    }
}

/* ---------------- GPIO Init ---------------- */
void GPIO_Init(void)
{
    RCC->AHB1ENR |= RCC_AHB1ENR_GPIOAEN;
    RCC->AHB1ENR |= RCC_AHB1ENR_GPIOBEN;

    /* PA1 -> LDR Input (digital read) */
    GPIOA->MODER &= ~(3U << (1 * 2));

    /* PB0 -> Laser */
    GPIOB->MODER &= ~(3U << (0 * 2));
    GPIOB->MODER |=  (1U << (0 * 2));

    /* PB1 -> Buzzer */
    GPIOB->MODER &= ~(3U << (1 * 2));
    GPIOB->MODER |=  (1U << (1 * 2));
    GPIOB->OTYPER &= ~((1U << 0) | (1U << 1));
}

