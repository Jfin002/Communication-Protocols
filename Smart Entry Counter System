LDR.c
#include "ldr.h"

void LDR_Init(void)
{
    /* Enable GPIOA Clock */
    RCC->AHB1ENR |= RCC_AHB1ENR_GPIOAEN;

    /* PA0 -> Analog Mode */
    GPIOA->MODER |= (3U << (0 * 2));

    /* Enable ADC1 Clock */
    RCC->APB2ENR |= RCC_APB2ENR_ADC1EN;

    /* Disable ADC before config */
    ADC1->CR2 = 0;

    /* 12-bit resolution */
    ADC1->CR1 = 0;

    /* Regular sequence: Channel 0 */
    ADC1->SQR3 = 0;

    /* Sampling time: 144 cycles */
    ADC1->SMPR2 |= (5U << 0);

    /* Power ON ADC */
    ADC1->CR2 |= ADC_CR2_ADON;
}

uint16_t LDR_Read(void)
{
    /* Start Conversion */
    ADC1->CR2 |= ADC_CR2_SWSTART;

    /* Wait until complete */
    while (!(ADC1->SR & ADC_SR_EOC));

    /* Read result */
    return (uint16_t)ADC1->DR;
}

