{
    int len = 0;
    while(*str++) len++;
    return len;
}

/* ---------------- MAIN ---------------- */
int main(void)
{
    GPIO_Init();
    I2C1_Init();
    LDR_Init();
    OLED_Init();

    /* Laser ON */
    GPIOB->ODR |= (1U << 0);
    /* Buzzer OFF */
    GPIOB->ODR &= ~(1U << 1);

    OLED_ShowStartupScreen();
    OLED_ShowCount(0);

    while(1)
    {
        /* Read LDR digital status (PA1) */
        ldr_status = (GPIOA->IDR & (1U << 1)) ? 1 : 0;

        if(prev_ldr_status == 1 && ldr_status == 0)
        {
            /* Laser blocked - person detected */
            block_count++;
            GPIOB->ODR |= (1U << 1);  /* Buzzer ON */
            delay_ms(150);
            GPIOB->ODR &= ~(1U << 1); /* Buzzer OFF */
            OLED_ShowCount(block_count);
        }
        prev_ldr_status = ldr_status;
        delay_ms(10);
    }
}
