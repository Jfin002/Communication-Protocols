static void intToStr(int num, char *str)
{
    int i = 0;
    if(num == 0)
    {
        str[i++] = '0';
        str[i] = '\0';
        return;
    }
    while(num > 0)
    {
        str[i++] = (num % 10) + '0';
        num /= 10;
    }
    str[i] = '\0';

    /* Reverse string */
    int start = 0, end = i - 1;
    char temp;
    while(start < end)
    {
        temp = str[start];
        str[start] = str[end];
        str[end] = temp;
        start++;
        end--;
    }
}

