main.c

#include "stm32f4xx.h"
#include "SPI.h"
#include "rfid.h"

/* ===== VARIABLES FOR LIVE EXPRESSION ===== */
volatile uint8_t uid[5] = {0};
volatile uint8_t card_detected = 0;
volatile uint8_t version = 0;

int main(void)
{
    spi_gpio_init();
    spi1_config();
    rfid_init();

    cs_disable();

    while(1)
    {
        version = rfid_read(0x37);   // keep SPI active for debugger visibility

        if(rfid_request((uint8_t*)uid))
            card_detected = 1;
        else
            card_detected = 0;

        // debugger-friendly delay (stable memory access)
        for(volatile uint32_t i = 0; i < 2000000; i++);
    }
}

