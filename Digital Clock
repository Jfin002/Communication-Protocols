void OLED_clear(void)
{
    for(int page=0; page<8; page++)
    {
        OLED_setCursor(page,0);
        for(int i=0;i<128;i++)
            OLED_writeData(0x00);
    }
}

void OLED_setCursor(uint8_t page, uint8_t column)
{
    OLED_writeCommand(0xB0 + page);
    OLED_writeCommand(0x00 + (column & 0x0F));
    OLED_writeCommand(0x10 + (column >> 4));
}

void OLED_printChar(char c)
{
    const uint8_t *bitmap = 0;

    if(c >= '0' && c <= '9')
        bitmap = font5x7[c-'0'];

    else if(c == 'D') bitmap = font_letters[0];
    else if(c == 'A') bitmap = font_letters[1];
    else if(c == 'T') bitmap = font_letters[2];
    else if(c == 'E') bitmap = font_letters[3];
    else if(c == 'I') bitmap = font_letters[4];
    else if(c == 'M') bitmap = font_letters[5];
    else if(c == ':') bitmap = font_letters[6];
    else if(c == '-') bitmap = font_letters[7];
    else bitmap = font_letters[8];

    for(int i=0;i<5;i++)
        OLED_writeData(bitmap[i]);

    OLED_writeData(0x00);
}


void OLED_printString(char *str)
{
    while(*str)
    {
        OLED_printChar(*str);
        str++;
    }
}

void OLED_printNumber(int num)
{
    char buffer[10];
    int i=0;

    if(num == 0)
    {
        OLED_printChar('0');
        return;
    }

    while(num > 0)
    {
        buffer[i++] = (num % 10) + '0';
        num /= 10;
    }

    for(int j=i-1; j>=0; j--)
        OLED_printChar(buffer[j]);
}

