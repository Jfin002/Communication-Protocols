#include <stdio.h>
#include "rtc.h"
#include "I2C.h"
#include "oled.h"

#define BUFF_LEN 20

uint8_t hour,min,sec;
uint8_t day,month,year;

uint8_t time_buff[BUFF_LEN] = {0};
uint8_t date_buff[BUFF_LEN] = {0};

static void display_rtc_calendar(void);


int main(void)
{
	/*Initialize debug I2C*/
    I2C1_init();
    OLED_init();
    OLED_clear();
    /*Initialize rtc*/
    rtc_init();

    uint8_t last_sec = 99;

    while(1)
    {
        sec = rtc_convert_bcd2dec(rtc_time_get_second());

        if(sec != last_sec)
        {
            last_sec = sec;
            display_rtc_calendar();
        }
    }
}

static void display_rtc_calendar(void)
{

	hour = rtc_convert_bcd2dec(rtc_time_get_hour());
	min = rtc_convert_bcd2dec(rtc_time_get_minute());
	sec = rtc_convert_bcd2dec(rtc_time_get_second());

	month = rtc_convert_bcd2dec(rtc_date_get_month());
	day = rtc_convert_bcd2dec(rtc_date_get_day());
	year = rtc_convert_bcd2dec(rtc_date_get_year());

	OLED_clear();

	//DATE -
	OLED_setCursor(0,0);
	OLED_printString("DATE:");
    //OLED_setCursor(2,0);
    /*Display format : dd : mm : yy*/
    sprintf((char*)date_buff,"%02d-%02d-20%02d",day,month,year);
    OLED_printString((char*)date_buff);

    /* TIME */
    OLED_setCursor(4,0);
    OLED_printString("TIME:");
    //OLED_setCursor(6,0);

    /*Display format : hh : mm : ss*/
    sprintf((char*)time_buff,"%02d:%02d:%02d",hour,min,sec);
    OLED_printString((char*)time_buff);

}
