#define OLED_ADDR 0x3C

/* Control bytes */
#define OLED_CMD   0x00
#define OLED_DATA  0x40

/* 5x7 Font */
static const uint8_t font5x7[][5] = {
{0x3E,0x51,0x49,0x45,0x3E}, // 0
{0x00,0x42,0x7F,0x40,0x00}, // 1
{0x42,0x61,0x51,0x49,0x46}, // 2
{0x21,0x41,0x45,0x4B,0x31}, // 3
{0x18,0x14,0x12,0x7F,0x10}, // 4
{0x27,0x45,0x45,0x45,0x39}, // 5
{0x3C,0x4A,0x49,0x49,0x30}, // 6
{0x01,0x71,0x09,0x05,0x03}, // 7
{0x36,0x49,0x49,0x49,0x36}, // 8
{0x06,0x49,0x49,0x29,0x1E}  // 9
};

/* Minimal font for RTC labels */
static const uint8_t font_letters[][5] = {
    /* D */ {0x7F,0x41,0x41,0x22,0x1C},
    /* A */ {0x7E,0x11,0x11,0x11,0x7E},
    /* T */ {0x01,0x01,0x7F,0x01,0x01},
    /* E */ {0x7F,0x49,0x49,0x49,0x41},
    /* I */ {0x41,0x7F,0x41,0x00,0x00},
    /* M */ {0x7F,0x02,0x04,0x02,0x7F},
    /* : */ {0x00,0x36,0x36,0x00,0x00},
    /* - */ {0x08,0x08,0x08,0x08,0x08},
    /* space */ {0x00,0x00,0x00,0x00,0x00}
};


static void OLED_writeCommand(uint8_t cmd)
{
    char data[2];
    data[0] = OLED_CMD;
    data[1] = cmd;
    I2C1_burstWrite(OLED_ADDR, data[0], 1, &data[1]);
}

static void OLED_writeData(uint8_t dataByte)
{
    char data[2];
    data[0] = OLED_DATA;
    data[1] = dataByte;
    I2C1_burstWrite(OLED_ADDR, data[0], 1, &data[1]);
}

void OLED_init(void)
{
    OLED_writeCommand(0xAE);
    OLED_writeCommand(0x20);
    OLED_writeCommand(0x10);
    OLED_writeCommand(0xB0);
    OLED_writeCommand(0xC8);
    OLED_writeCommand(0x00);
    OLED_writeCommand(0x10);
